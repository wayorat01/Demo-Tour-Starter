{
  "name": "payblocks",
  "version": "2.11.0",
  "description": "A Website template for PayloadCMS, featurig shadcn/ui and shadcnblocks.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "pnpm payload generate:types && cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8192\" next build",
    "analyze": "cross-env ANALYZE=true NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8192\" pnpm build",
    "dev": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8192\" next dev",
    "dev:fast": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8192\" next dev",
    "dev:debug": "cross-env NODE_OPTIONS='--no-deprecation --inspect' next dev",
    "dev:turbo": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8192\" next dev --turbo",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rimraf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "tsc": "cross-env NODE_OPTIONS=--no-deprecation tsc --noEmit",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation next lint --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rimraf node_modules pnpm-lock.yaml && pnpm --ignore-workspace install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "backup": "source .env && mongoexport -c pages --uri=$MONGODB_URI --out backup/pages.json --jsonArray",
    "backup:apply": "source .env && mongoimport -c pages --uri=$MONGODB_URI --file backup/pages.json --jsonArray --mode upsert",
    "seed:generate": "node --import tsx scripts/seed.ts generate",
    "seed:apply": "node --import tsx scripts/seed.ts apply",
    "seed:preview": "node --import tsx scripts/seed.ts preview",
    "test": "playwright test",
    "test:quick": "playwright test tests/homepage.spec.ts --project=Desktop",
    "test:lighthouse": "lhci autorun",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ],
    "*.{ts,tsx,css,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@fontsource/kanit": "^5.2.8",
    "@fontsource/noto-sans-thai": "^5.2.8",
    "@fontsource/noto-sans-thai-looped": "^5.2.10",
    "@payloadcms/admin-bar": "3.59.1",
    "@payloadcms/db-mongodb": "3.59.1",
    "@payloadcms/email-resend": "3.59.1",
    "@payloadcms/live-preview-react": "3.59.1",
    "@payloadcms/next": "3.59.1",
    "@payloadcms/plugin-form-builder": "3.59.1",
    "@payloadcms/plugin-nested-docs": "3.59.1",
    "@payloadcms/plugin-redirects": "3.59.1",
    "@payloadcms/plugin-search": "3.59.1",
    "@payloadcms/plugin-seo": "3.59.1",
    "@payloadcms/richtext-lexical": "3.59.1",
    "@payloadcms/storage-s3": "^3.59.1",
    "@payloadcms/storage-vercel-blob": "3.59.1",
    "@payloadcms/translations": "3.59.1",
    "@payloadcms/ui": "3.59.1",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-navigation-menu": "^1.2.5",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toggle": "^1.1.2",
    "@radix-ui/react-toggle-group": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@types/papaparse": "^5.5.2",
    "@vercel/analytics": "^1.5.0",
    "@vercel/blob": "^0.27.2",
    "bson": "^6.10.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cross-env": "^7.0.3",
    "date-fns": "^4.1.0",
    "embla-carousel-auto-scroll": "^8.5.2",
    "embla-carousel-autoplay": "^8.5.2",
    "embla-carousel-fade": "^8.5.2",
    "embla-carousel-react": "^8.5.2",
    "geist": "^1.3.1",
    "graphql": "^16.10.0",
    "jsonwebtoken": "9.0.2",
    "lexical": "^0.35.0",
    "lucide-react": "^0.483.0",
    "motion": "^12.16.0",
    "next": "15.4.8",
    "nodemailer": "^8.0.1",
    "papaparse": "^5.5.3",
    "payload": "3.59.1",
    "payload-oauth2": "1.0.18",
    "prism-react-renderer": "^2.4.1",
    "react": "19.2.0",
    "react-day-picker": "^9.13.1",
    "react-dom": "19.2.0",
    "react-hook-form": "7.52.2",
    "react-icons": "^5.5.0",
    "react-number-format": "^5.4.4",
    "react-phone-number-input": "^3.4.12",
    "react-responsive-masonry": "^2.7.1",
    "react-turnstile": "^1.1.4",
    "sharp": "0.34.5",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tar-stream": "^3.1.7"
  },
  "devDependencies": {
    "@changesets/cli": "^2.28.1",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "15.4.7",
    "@next/eslint-plugin-next": "15.4.7",
    "@payloadcms/eslint-config": "^3.28.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.6",
    "@tailwindcss/typography": "^0.5.16",
    "@types/escape-html": "^1.0.4",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "22.5.4",
    "@types/nodemailer": "^7.0.10",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@types/tar-stream": "^3.1.3",
    "copyfiles": "^2.4.1",
    "dotenv": "^17.2.4",
    "eslint": "^9.38.0",
    "eslint-config-next": "15.4.7",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "mongodb": "^7.1.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.1.6",
    "tsx": "^4.21.0",
    "typescript": "5.6.3"
  },
  "engines": {
    "node": "^18.20.2 || ^20.9.0 || ^22.0.0 || ^23.6.0 || ^24.6.0"
  },
  "packageManager": "pnpm@9.15.9",
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.2",
      "@types/react-dom": "19.2.2"
    }
  }
}
